PORT=3000

# OpenAI-compatible base URL. Examples:
# https://api.openai.com/v1
# https://your-relay.example.com/v1
# https://openrouter.ai/api/v1
LLM_BASE_URL=https://api.openai.com/v1

# API key for your relay or provider
LLM_API_KEY=your_api_key_here

# Model id exposed by your provider or relay
LLM_MODEL=gpt-4o-mini

# Optional tuning
LLM_TIMEOUT_MS=45000
LLM_CONNECT_TIMEOUT_MS=15000
LLM_TEMPERATURE=0.1

# Optional proxy override for the backend's outbound LLM request.
# If omitted, the backend will also respect HTTPS_PROXY / HTTP_PROXY / ALL_PROXY.
# LLM_PROXY_URL=http://127.0.0.1:7890

# Optional extra headers as JSON string, useful for some relays
# LLM_EXTRA_HEADERS_JSON={"HTTP-Referer":"https://your-site.example","X-Title":"LLaMb Analyzer"}
